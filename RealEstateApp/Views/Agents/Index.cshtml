@model IEnumerable<RealEstateApp.Models.Agent>

@{
    ViewData["Title"] = "Our Consultants";
}

<div class="container mt-5 mb-5">
    <div class="text-center mb-5">
        <h1 class="fw-bold">Meet Our Consultants</h1>
        <p class="text-muted">Expert guidance for your real estate journey.</p>

        @if (User.IsInRole("Admin"))
        {
            <a asp-action="Create" class="btn btn-primary mt-3">
                <i class="bi bi-plus-lg"></i> Add New Agent
            </a>
        }
    </div>

    <div class="row g-4">
        @foreach (var item in Model)
        {
            <div class="col-md-6 col-lg-4">
                <div class="card border-0 shadow-sm text-center h-100 p-4">
                    <div class="mx-auto mb-3" style="width: 120px; height: 120px;">
                        <img src="/images/@item.ImageUrl" class="rounded-circle w-100 h-100 shadow" style="object-fit: cover;" alt="@item.FullName">
                    </div>

                    <h4 class="fw-bold mb-1">@item.FullName</h4>
                    <p class="text-primary small text-uppercase fw-bold mb-3">@item.Bio</p>

                    <div class="d-flex justify-content-center gap-2 mb-4">
                        <a href="mailto:@item.Email" class="btn btn-light rounded-circle text-primary"><i class="bi bi-envelope-fill"></i></a>
                        <a href="tel:@item.PhoneNumber" class="btn btn-light rounded-circle text-success"><i class="bi bi-telephone-fill"></i></a>
                    </div>

                    <ul class="list-unstyled bg-light p-3 rounded text-start small text-secondary">
                        <li class="mb-2"><i class="bi bi-envelope me-2"></i> @item.Email</li>
                        <li><i class="bi bi-phone me-2"></i> @item.PhoneNumber</li>
                    </ul>

                    @if (User.IsInRole("Admin"))
                    {
                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-outline-danger btn-sm w-100 mt-3" onclick="return confirm('Delete this agent?');">Remove Agent</a>
                    }
                </div>
            </div>
        }
    </div>
</div>